<%- include('partials/header', { pageTitle: 'Dashboard' }) %>

<div class="container">


  <div class="page-header d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div>
      <h1><i class="bi bi-speedometer2 me-2"></i>Dashboard</h1>
      <p>Manage your entire car fleet from one place.</p>
    </div>
    <span class="badge bg-white text-primary fw-semibold fs-6 px-3 py-2 rounded-pill shadow-sm">
      <%= cars.length %> car<%= cars.length !== 1 ? 's' : '' %>
    </span>
  </div>

  <div class="row g-4">


    <div class="col-lg-4">
      <div class="card h-100">
        <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
          <h2 class="h5 fw-bold mb-0">
            <i class="bi bi-plus-circle me-2 text-primary"></i>Add New Car
          </h2>
        </div>
        <div class="card-body p-4">
          <form action="/car" method="POST" class="needs-validation" novalidate>

            <div class="mb-3">
              <label for="car-name" class="form-label">Car Name</label>
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-car-front"></i></span>
                <input
                  id="car-name"
                  class="form-control"
                  name="carName"
                  placeholder="e.g. Honda City"
                  required
                />
                <div class="invalid-feedback">Car name is required.</div>
              </div>
            </div>

            <div class="mb-3">
              <label for="car-price" class="form-label">Price (₹)</label>
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-currency-rupee"></i></span>
                <input
                  id="car-price"
                  class="form-control"
                  name="price"
                  type="number"
                  min="0"
                  placeholder="e.g. 800000"
                  required
                />
                <div class="invalid-feedback">A valid price is required.</div>
              </div>
            </div>

            <div class="mb-4">
              <label for="car-seater" class="form-label">Seats</label>
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-people"></i></span>
                <input
                  id="car-seater"
                  class="form-control"
                  name="seater"
                  type="number"
                  min="1"
                  placeholder="e.g. 5"
                />
              </div>
            </div>

            <button type="submit" class="btn btn-primary w-100 fw-semibold py-2">
              <i class="bi bi-plus-lg me-2"></i>Add Car
            </button>

          </form>
        </div>
      </div>
    </div>


    <div class="col-lg-8">
      <div class="card">
        <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
          <h2 class="h5 fw-bold mb-0">
            <i class="bi bi-list-ul me-2 text-primary"></i>Your Fleet
          </h2>
        </div>
        <div class="card-body p-0 pt-3">

          <% if (cars.length === 0) { %>
            <div class="text-center py-5 text-muted">
              <i class="bi bi-car-front display-4 d-block mb-2 opacity-25"></i>
              <p class="mb-0">No cars yet — add your first one!</p>
            </div>
          <% } else { %>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th class="ps-4">#</th>
                    <th><i class="bi bi-car-front me-1"></i>Name</th>
                    <th><i class="bi bi-currency-rupee me-1"></i>Price</th>
                    <th><i class="bi bi-people me-1"></i>Seats</th>
                    <th class="text-end pe-4">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% cars.forEach((car, i) => { %>
                    <tr>
                      <td class="ps-4 text-muted small"><%= i + 1 %></td>
                      <td class="fw-semibold">
                        <a href="/car/<%= car._id %>" class="text-decoration-none text-dark"><%= car.carName %></a>
                      </td>
                      <td>
                        <span class="badge bg-success-subtle text-success fw-semibold px-2 py-1 rounded-pill">
                          ₹<%= car.price.toLocaleString('en-IN') %>
                        </span>
                      </td>
                      <td>
                        <span class="badge bg-info-subtle text-info fw-semibold px-2 py-1 rounded-pill">
                          <i class="bi bi-people me-1"></i><%= car.seater %>
                        </span>
                      </td>
                      <td class="text-end pe-4">
                        <a href="/car/<%= car._id %>"
                           class="btn btn-sm btn-outline-secondary me-1"
                           title="View">
                          <i class="bi bi-eye"></i>
                        </a>
                        <a href="/car/<%= car._id %>/edit"
                           class="btn btn-sm btn-outline-primary me-1"
                           title="Edit">
                          <i class="bi bi-pencil"></i>
                        </a>
                        <a href="/car/<%= car._id %>/delete"
                           class="btn btn-sm btn-outline-danger"
                           title="Delete"
                           onclick="return confirm('Delete <%= car.carName %>?')">
                          <i class="bi bi-trash"></i>
                        </a>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>

        </div>
      </div>
    </div>

</div>
</div>

<%- include('partials/footer') %>