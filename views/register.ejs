<%- include('partials/header', { pageTitle: 'Register' }) %>

<div class="auth-wrapper">
  <div class="auth-card">

    <div class="card">
      <div class="card-body p-4 p-md-5">


        <div class="text-center mb-4">
          <div class="mb-2">
            <i class="bi bi-person-plus-fill fs-1 text-primary"></i>
          </div>
          <h1 class="h3 fw-bold mb-1">Create an account</h1>
          <p class="text-muted small">Join CarShala and start managing your vehicles</p>
        </div>


        <form action="/register" method="POST" class="needs-validation" novalidate>

          <div class="mb-3">
            <label for="reg-username" class="form-label">Username</label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-person"></i></span>
              <input
                id="reg-username"
                class="form-control"
                name="username"
                placeholder="Choose a username"
                required
                autocomplete="username"
              />
              <div class="invalid-feedback">Username is required.</div>
            </div>
          </div>

          <div class="mb-3">
            <label for="reg-password" class="form-label">Password</label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-lock"></i></span>
              <input
                id="reg-password"
                class="form-control"
                name="password"
                type="password"
                placeholder="Create a password"
                required
                autocomplete="new-password"
              />
              <div class="invalid-feedback">Password is required.</div>
            </div>
          </div>

          <div class="mb-3">
            <label for="reg-licence" class="form-label">Licence Number</label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-card-text"></i></span>
              <input
                id="reg-licence"
                class="form-control"
                name="licence"
                placeholder="e.g. DL-0420110012345"
                required
              />
              <div class="invalid-feedback">Licence number is required.</div>
            </div>
          </div>

          <div class="mb-3">
            <label for="reg-age" class="form-label">Age</label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-calendar3"></i></span>
              <input
                id="reg-age"
                class="form-control"
                name="age"
                type="number"
                min="18"
                placeholder="e.g. 25"
                required
              />
              <div class="invalid-feedback">Age is required (min 18).</div>
            </div>
          </div>

          <div class="mb-4">
            <label for="reg-owner" class="form-label">Owner Name</label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-person-badge"></i></span>
              <input
                id="reg-owner"
                class="form-control"
                name="owner"
                placeholder="Full name as on RC"
                required
              />
              <div class="invalid-feedback">Owner name is required.</div>
            </div>
          </div>

          <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
            <i class="bi bi-person-check me-2"></i>Register
          </button>

        </form>

        <hr class="my-4"/>

        <p class="text-center text-muted small mb-0">
          Already have an account?
          <a href="/login" class="fw-semibold text-decoration-none">Sign in</a>
        </p>

      </div>
    </div>

  </div>
</div>

<%- include('partials/footer') %>